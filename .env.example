# ── PROVIDER SELECTION ──────────────────────────────────────
# Options: anthropic | groq | gemini | openrouter
PROVIDER=groq

# ── DATA SOURCE KEYS ────────────────────────────────────────

# Dune Analytics (free) → https://dune.com/settings/api
DUNE_API_KEY=
# Override default Hyperliquid query IDs (comma-separated)
# DUNE_QUERY_IDS=3455783,3685970

# Binance API key (optional — only needed if HYPE listed on Binance perps)
# BINANCE_API_KEY=

# ── LLM API KEYS (only fill the one matching your PROVIDER) ─

# Groq (free) → https://console.groq.com
GROQ_API_KEY=gsk_your-key-here

# Google Gemini (free) → https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza_your-key-here

# Anthropic (paid) → https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenRouter (free tier) → https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# ── MODEL OVERRIDE (optional, uses smart default per provider)
# MODEL=llama-3.3-70b-versatile

# ── BROWSER ─────────────────────────────────────────────────
# false = show browser window (debug), true = headless (prod)
HEADLESS=false

# ── SERVER ──────────────────────────────────────────────────
PORT=8000
MAX_PARALLEL_SCRAPERS=5
